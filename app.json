{
  "expo": {
    "name": "TrickyHr",
    "slug": "trickyhr",
    "version": "3.5.3",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "trickyhr",
    "updates": {
      "enabled": false
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mykevit.kevit",
      "buildNumber": "2",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app uses location to mark employee attendance and verify work locations during duty hours.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "For employees assigned to live tracking duties, this app collects location updates in the background during working hours for attendance verification and field staff monitoring.",
        "NSLocationAlwaysUsageDescription": "For employees assigned to live tracking duties, this app tracks location in the background during working hours for monitoring and attendance purposes.",
        "UIBackgroundModes": ["location", "fetch"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mykevit.www.trickyhr",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"],
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/images/adptive-icon.png",
        "backgroundImage": "./assets/images/background.png"
      },
      "versionCode": 115,
      "userInterfaceStyle": "automatic",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "ndkVersion": "26.1.10909125",
            "usesCleartextTraffic": true,
            "packagingOptions": {
              "pickFirst": []
            }
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#121212"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "novaframes"
        }
      ],
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6bd55208-929c-4904-8e56-61fa84d11eca"
      }
    }
  }
}
